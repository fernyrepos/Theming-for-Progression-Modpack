<!-- 6. Harmless startup errors -->
<PopupFramework.PopupDef>
	<defName>ProgressionGameStartPopup6</defName>
	<title>Harmless startup errors</title>
	<description>
&lt;size=20&gt;&lt;b&gt;Don&#39;t stress. Your game's not broken silly!&lt;/b&gt;&lt;/size&gt;
\n
&lt;size=18&gt;When you close this popup, you may notice red error messages appear in the log. This is &lt;b&gt;normal&lt;/b&gt; during a fresh startup of the modpack and is primarily used by the developers for debugging and tracking edge cases.&lt;/size&gt;
\n
All known startup errors have been reviewed by the community and are either confirmed to be harmless or actively being worked on. None of them indicate a broken or unstable experience. Feel free to ignore them and just play the game.	</description>
	<iconPath>Tutor/Errors</iconPath>
	<dimensions>(988, 620)</dimensions>
	<orientationStyle>Right</orientationStyle>
	<closeable>false</closeable>
	<oneTime>true</oneTime>
